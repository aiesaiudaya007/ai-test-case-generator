# --- Jira ---
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your_jira_api_token   # https://id.atlassian.com/manage-profile/security/api-tokens

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
# Check https://docs.claude.com/en/docs/about-claude/models for the current model id
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# --- Webhook / SDLC integration (webhook_server.py) ---
# Shared secret Jira Automation must send back as the X-Webhook-Secret header.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=change_me_to_a_random_secret
# Only stories that transition INTO this status trigger generation.
TRIGGER_STATUS=Ready for QA
